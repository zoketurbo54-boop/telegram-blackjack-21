# Скопируйте на сервер: cp .env.example .env && nano .env

BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ваш Telegram user id (для /bot_stars) — узнать у @userinfobot
TELEGRAM_ADMIN_ID=

# Прокси не нужен, если VPS видит api.telegram.org (типично Beget в EU)
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_PROXY_HOST=
# TELEGRAM_PROXY_PORT=
# TELEGRAM_PROXY_USER=
# TELEGRAM_PROXY_PASSWORD=

TELEGRAM_FORCE_IPV4=1
TELEGRAM_REQUEST_TIMEOUT=90
TELEGRAM_CONNECT_RETRIES=6
TELEGRAM_CONNECT_DELAY=3
